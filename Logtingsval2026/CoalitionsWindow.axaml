<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Logtingsval2026.CoalitionsWindow"
        Title="Løgtingsval — meiriluti"
        Width="920"
        Height="640"
        MinWidth="640"
        MinHeight="400">
  <DockPanel>
    <TextBlock x:Name="InfoHeader"
               DockPanel.Dock="Top"
               Margin="12,10,12,6"
               TextWrapping="Wrap"
               Opacity="0.9" />
    <TabControl Margin="8,0,8,8">
      <TabItem Header="Minsti meiriluti">
        <ScrollViewer x:Name="ScrollMinimal"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto" />
      </TabItem>
      <TabItem Header="Øll samslög">
        <ScrollViewer x:Name="ScrollAll"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto" />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
